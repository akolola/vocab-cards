<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vocab Cards"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="German - Russian flashcards"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnPickFile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Open different file…"
        android:textSize="16sp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:text="Pick an Excel file with a sheet named Fokus" />

    <Button
        android:id="@+id/btnStartAll"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Start all"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnStartWrong"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Review wrong"
        android:textSize="22sp"
        android:textStyle="bold"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnClearWrong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear wrong list"
        android:textSize="15sp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:visibility="gone" />

</LinearLayout>
