<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Progress bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review"
            android:textSize="12sp"
            android:textColor="@color/badge_f"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvSubsection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvSectionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_bg" />
    </LinearLayout>

    <!-- ======== CARD CONTENT ======== -->
    <ScrollView
        android:id="@+id/cardLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Word block -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_word_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:background="@drawable/badge_bg"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvArticle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="24sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginEnd="6dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Russian translation (col C) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/rowRussian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_ru_bg">

                <TextView
                    android:id="@+id/tvRussian"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:textSize="26sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.15" />
            </androidx.cardview.widget.CardView>

            <!-- Extra info (col D, E, F… combined) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/rowExtra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_notes_bg">

                <TextView
                    android:id="@+id/tvExtra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="18dp"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.15" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ======== FINISHED SCREEN ======== -->
    <LinearLayout
        android:id="@+id/finishedLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFinishedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All cards done!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvFinishedWrong"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/badge_f"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnReviewWrong2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review wrong cards"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRestartAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start from beginning"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <!-- ======== NAVIGATION BUTTONS ======== -->
    <!-- Row 1: Wrong (full width, tonal) -->
    <Button
        android:id="@+id/btnWrong"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:text="Mark"
        android:textSize="20sp"
        android:textStyle="bold"
        style="@style/Widget.Material3.Button.TonalButton" />

    <!-- Row 2: Prev | Next (side by side, large) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:background="@color/background">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="&lt;&lt; Prev"
            android:textSize="20sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="2"
            android:text="Show"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <!-- Mid-deck review wrong shortcut (shown at last card) -->
    <Button
        android:id="@+id/btnReviewWrong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:text="Review wrong cards"
        style="@style/Widget.Material3.Button.TonalButton"
        android:visibility="gone" />

</LinearLayout>
